{
  "safe_write_paths": [
    "~/.claude",
    "/tmp",
    "~/workspace",
    "~/projects",
    "~/dev",
    "~/Obsidian",
    "~/Documents/notes"
  ],
  "exclude_patterns": [
    "git push.*--force",
    "git push.*-f\\b",
    "kubectl delete.*--all",
    "DROP TABLE",
    "rm -rf /"
  ],
  "mcp_allow_patterns": [
    "^mcp__code-review-graph__"
  ],
  "sound": true
}
